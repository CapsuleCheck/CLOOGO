{
  "expo": {
    "owner": "errandgo",
    "name": "ErrandGo",
    "slug": "errandgo",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#10b981"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.errandgo.app",
      "infoPlist": {
        "NSPhotoLibraryUsageDescription": "Allow ErrandGo to access your photos to attach item images.",
        "NSCameraUsageDescription": "Allow ErrandGo to use your camera to take item photos.",
        "UIBackgroundModes": [
          "remote-notification"
        ],
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#10b981"
      },
      "package": "com.errandgo.app",
      "permissions": [
        "android.permission.NOTIFICATIONS",
        "android.permission.READ_MEDIA_IMAGES",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO"
      ],
      "versionCode": 2
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "bundler": "metro"
    },
    "plugins": [
      "expo-router",
      [
        "expo-notifications",
        {
          "icon": "./assets/icon.png",
          "color": "#10b981",
          "sounds": []
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Allow ErrandGo to access your photos.",
          "cameraPermission": "Allow ErrandGo to take photos of items."
        }
      ]
    ],
    "scheme": "errandgo",
    "extra": {
      "router": {
        "origin": false
      },
      "eas": {
        "projectId": "95d672bb-6e45-4edd-87b3-1e46d38b9215"
      }
    }
  }
}
